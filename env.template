# Brock Environment Variables
# Copy this file to .env for local development.
#
# Only private values or environment-specific overrides belong here.
# Worktree-specific ports and local service URLs are generated into .env.local.

# =============================================================================
# Local development
# =============================================================================

# Optional local S3 bucket override
S3_BUCKET=brock-uploads

# Optional AWS region override for local or remote S3-compatible storage
AWS_REGION=us-east-1

# =============================================================================
# Production / deployment variables
# =============================================================================

# Phoenix host, only required outside local development
PHX_HOST=

# Secrets used outside local development
SECRET_KEY_BASE=
TOKEN_SIGNING_SECRET=

# Optional direct database override for deployments
DATABASE_URL=

# Optional S3-compatible credentials / endpoint overrides
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_HOST=
S3_SCHEME=
S3_PORT=
